{
  "name": "vsc_tree_plugin",
  "displayName": "Tree Generator",
  "version": "1.0.0",
  "description": "Generate tree.tree file and provide syntax highlighting",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
  ],
  "contributes": {
    "languages": [
      {
        "id": "tree",
        "extensions": [".tree"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tree",
        "scopeName": "source.tree",
        "path": "./syntaxes/tree.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "tree-generator.generateTree",
        "title": "Generate Tree File"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "keywords": [],
  "author": "Northengate",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.1",
      "onFail": "download"
    }
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0",
    "typescript": "^6.0.3"
  }
}
